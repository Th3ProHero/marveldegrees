generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Actor {
  id          Int          @id // TMDB ID
  name        String
  profilePath String?      @map("profile_path")
  popularity  Float        @default(0)
  isMcu       Boolean      @default(false) @map("is_mcu")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  movies      ActorMovie[]

  @@map("actors")
}

model Movie {
  id          Int          @id // TMDB ID
  title       String
  posterPath  String?      @map("poster_path")
  releaseDate String?      @map("release_date")
  overview    String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  actors      ActorMovie[]

  @@map("movies")
}

model ActorMovie {
  actorId   Int      @map("actor_id")
  movieId   Int      @map("movie_id")
  character String?
  creditOrder Int?   @map("credit_order")
  actor     Actor    @relation(fields: [actorId], references: [id], onDelete: Cascade)
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@id([actorId, movieId])
  @@map("actor_movies")
}

model CachedPath {
  id            Int      @id @default(autoincrement())
  sourceActorId Int      @map("source_actor_id")
  targetActorId Int      @map("target_actor_id")
  sourceName    String   @map("source_name")
  targetName    String   @map("target_name")
  degreesCount  Int      @map("degrees_count")
  pathData      String   @map("path_data")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([sourceActorId])
  @@index([sourceActorId])
  @@map("cached_paths")
}

model McuSeedActor {
  id        Int    @id @default(autoincrement())
  tmdbId    Int    @unique @map("tmdb_id")
  name      String
  character String

  @@map("mcu_seed_actors")
}
